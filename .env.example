# PostgreSQL (local dev uses port 5433 to avoid conflicts — see docker-compose.yml)
DATABASE_URL=postgresql://dhp:dhp_dev_password@localhost:5433/dhp_dev

# Redis (BullMQ jobs + §2.2 real-time Pub/Sub fan-out; port 6380 locally)
REDIS_URL=redis://:dhp_redis_password@localhost:6380

# AuthPlex (self-hosted OIDC) — §7A
# Local dev: reuse the running hams-authplex-1 container on :8080
# Run scripts/register-authplex-client.sh once to register the dhp-web OIDC client.
OIDC_ISSUER=http://localhost:8080
OIDC_AUDIENCE=dhp-api
OIDC_CLIENT_ID=dhp-web
# JWKS URI defaults to {OIDC_ISSUER}/.well-known/jwks.json if not set
OIDC_JWKS_URI=http://localhost:8080/.well-known/jwks.json

# Web app (Vite — must be prefixed VITE_ to be exposed to the browser)
# These must also be set in apps/web/.env.local for local dev.
VITE_OIDC_ISSUER=http://localhost:8080
VITE_OIDC_CLIENT_ID=dhp-web
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_API_BASE_URL=http://localhost:3000

# Service-to-service token (Core → AI, §7A.2)
# Short-lived; carries sub=svc-core, org=organization_id, scope=ai:read
SERVICE_TOKEN_SECRET=change_me_32_bytes_minimum_secret
SERVICE_TOKEN_EXPIRY_SECONDS=300

# AI Service
CORE_API_URL=http://localhost:3000
OPENAI_API_KEY=sk-...
# Or: ANTHROPIC_API_KEY=sk-ant-...
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# Email dispatch (§4 module 8/9) — pick one provider; SMTP is the fallback
EMAIL_PROVIDER=ses
AWS_REGION=us-east-1
AWS_SES_FROM_ADDRESS=no-reply@example.com
# SENDGRID_API_KEY=SG....
# MAILGUN_API_KEY=...

# Token vault — KMS envelope encryption for OAuth tokens (§10)
TOKEN_VAULT_KEY=change_me_aes256_key_hex_64_chars

# Developer API — HMAC-SHA256 webhook signing (§4 module 12)
WEBHOOK_SIGNING_SECRET=change_me_32_bytes_webhook_secret

# §7A.4a — Billing provider webhook secret (Stripe / Paddle)
# subscription_status and subscription_expires_at are written ONLY via this webhook.
BILLING_WEBHOOK_SECRET=change_me_billing_webhook_secret
BILLING_PROVIDER=stripe   # stripe | paddle

# §2.2 Real-time layer — SSE heartbeat interval (ms)
SSE_HEARTBEAT_INTERVAL_MS=15000

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=debug

# Flyway (used by docker-compose migration service; not needed at runtime)
FLYWAY_URL=jdbc:postgresql://localhost:5432/dhp_dev
FLYWAY_USER=dhp
FLYWAY_PASSWORD=dhp_dev_password

# SendGrid — invite emails
SENDGRID_API_KEY=SG.your_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourhospital.com
APP_BASE_URL=http://localhost:5173
