generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), btree_gist]
}

// ─── Tenancy ──────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED

  @@map("subscription_status")
}

model Organization {
  id                        String             @id @default(uuid()) @db.Uuid
  slug                      String             @unique
  name                      String
  brandingJson              Json?              @map("branding_json")
  senderDisplayName         String?            @map("sender_display_name")
  /// §7A.4a gate 0 — written only by billing-provider webhook; never by app code.
  subscriptionStatus        SubscriptionStatus @default(TRIALING) @map("subscription_status")
  subscriptionExpiresAt     DateTime?          @map("subscription_expires_at")
  billingProviderCustomerId String?            @map("billing_provider_customer_id")
  deletedAt                 DateTime?          @map("deleted_at")
  createdAt                 DateTime           @default(now()) @map("created_at")
  updatedAt                 DateTime           @updatedAt @map("updated_at")

  memberships       OrgMember[]
  users             User[]
  meetingTypes      MeetingType[]
  bookings          Booking[]
  availabilities    AvailabilitySchedule[]
  overrides         AvailabilityOverride[]
  oauthIntegrations OAuthIntegration[]
  apiKeys           ApiKey[]
  webhookEndpoints  WebhookEndpoint[]
  webhookDeliveries WebhookDelivery[]
  notificationAudit NotificationAudit[]
  aiEmbeddings      AiEmbedding[]
  outbox            Outbox[]
  adminAudit        AdminAudit[]
  featureFlags      FeatureFlag[]

  @@map("organizations")
}

model User {
  id              String    @id @db.Uuid // = AuthPlex OIDC sub
  organizationId  String    @map("organization_id") @db.Uuid
  username        String
  email           String
  timezone        String    @default("UTC")
  preferencesJson Json      @default("{}") @map("preferences_json") // flexible user prefs
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  organization      Organization           @relation(fields: [organizationId], references: [id])
  membership        OrgMember?
  meetingTypes      MeetingType[]
  bookings          Booking[]              @relation("HostBookings")
  availabilities    AvailabilitySchedule[]
  overrides         AvailabilityOverride[]
  oauthIntegrations OAuthIntegration[]
  aiEmbeddings      AiEmbedding[]

  // username unique per org — guests need only be unique within the org namespace
  @@unique([organizationId, username])
  @@index([organizationId])
  @@map("users")
}

model OrgMember {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  userId         String?         @unique @map("user_id") @db.Uuid // NULL until invite accepted
  role           MemberRole
  status         OrgMemberStatus @default(INVITED)
  invitedBy      String?         @map("invited_by") @db.Uuid
  invitedEmail   String          @map("invited_email")
  inviteToken    String?         @unique @map("invite_token")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("org_members")
}

enum MemberRole {
  SUPER_ADMIN
  ADMIN
  MAINTAINER
  MEMBER

  @@map("member_role")
}

enum OrgMemberStatus {
  INVITED
  ACTIVE
  REMOVED

  @@map("membership_status")
}

// ─── Meeting Types ────────────────────────────────────────────────────────────

model MeetingType {
  id                  String           @id @default(uuid()) @db.Uuid
  organizationId      String           @map("organization_id") @db.Uuid
  ownerUserId         String           @map("owner_user_id") @db.Uuid
  slug                String
  name                String
  description         String?
  durationMinutes     Int              @map("duration_minutes")
  conferencingType    ConferencingType @map("conferencing_type")
  // Normalized: buffer is two atomic columns, not a JSONB blob
  bufferBeforeMinutes Int              @default(0) @map("buffer_before_minutes")
  bufferAfterMinutes  Int              @default(0) @map("buffer_after_minutes")
  minNoticeMinutes    Int              @default(0) @map("min_notice_minutes")
  maxDaysInFuture     Int              @default(60) @map("max_days_in_future")
  maxPerDay           Int?             @map("max_per_day")
  isActive            Boolean          @default(true) @map("is_active")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  organization Organization          @relation(fields: [organizationId], references: [id])
  owner        User                  @relation(fields: [ownerUserId], references: [id])
  questions MeetingTypeQuestion[]  // normalized from questionsJson
  bookings  Booking[]

  @@unique([organizationId, ownerUserId, slug])
  @@index([organizationId])
  @@index([organizationId, ownerUserId, isActive])
  @@map("meeting_types")
}

// Normalized from meeting_types.questions_json
model MeetingTypeQuestion {
  id            String       @id @default(uuid()) @db.Uuid
  meetingTypeId String       @map("meeting_type_id") @db.Uuid
  position      Int          // display order
  label         String
  questionType  QuestionType @map("question_type")
  required      Boolean      @default(false)
  createdAt     DateTime     @default(now()) @map("created_at")

  meetingType MeetingType           @relation(fields: [meetingTypeId], references: [id], onDelete: Cascade)
  options     MeetingTypeQuestionOption[]
  answers     BookingAnswer[]

  @@index([meetingTypeId])
  @@map("meeting_type_questions")
}

// Options for select / multiselect question types
model MeetingTypeQuestionOption {
  id         String @id @default(uuid()) @db.Uuid
  questionId String @map("question_id") @db.Uuid
  position   Int
  label      String

  question MeetingTypeQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("meeting_type_question_options")
}

enum QuestionType {
  text
  select
  multiselect
  checkbox
}

enum ConferencingType {
  google_meet
  zoom
  teams
  webex
  custom
  in_person

  @@map("conferencing_type")
}

// ─── Availability ─────────────────────────────────────────────────────────────

model AvailabilitySchedule {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  ownerUserId    String   @map("owner_user_id") @db.Uuid
  name           String
  timezone       String   // IANA tz identifier
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id])
  owner        User              @relation(fields: [ownerUserId], references: [id])
  rules        AvailabilityRule[] // normalized from weeklyRules JSONB

  @@index([organizationId, ownerUserId])
  @@map("availability_schedules")
}

// Normalized from availability_schedules.weekly_rules
model AvailabilityRule {
  id         String @id @default(uuid()) @db.Uuid
  scheduleId String @map("schedule_id") @db.Uuid
  dayOfWeek  Int    @map("day_of_week") // 0=Sun … 6=Sat
  startTime  String @map("start_time")  // HH:mm, interpreted in schedule.timezone
  endTime    String @map("end_time")    // HH:mm

  schedule AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@map("availability_rules")
}

model AvailabilityOverride {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  ownerUserId    String   @map("owner_user_id") @db.Uuid
  date           DateTime @db.Date // stored as DATE; interpreted in user's timezone
  available      Boolean
  startTime      String?  @map("start_time") // HH:mm; only meaningful when available=true
  endTime        String?  @map("end_time")
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  owner        User         @relation(fields: [ownerUserId], references: [id])

  @@unique([organizationId, ownerUserId, date]) // one override per host per day
  @@index([organizationId, ownerUserId])
  @@map("availability_overrides")
}

// ─── Bookings ─────────────────────────────────────────────────────────────────

model Booking {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  hostId         String        @map("host_id") @db.Uuid
  meetingTypeId  String        @map("meeting_type_id") @db.Uuid
  guestEmail     String        @map("guest_email")
  guestName      String        @map("guest_name")
  // Discrete columns for Prisma; DB also has a GENERATED tstzrange column
  // used exclusively by the GiST EXCLUDE constraint (see migration SQL).
  startsAt       DateTime      @map("starts_at")
  endsAt         DateTime      @map("ends_at")
  status         BookingStatus @default(PENDING)
  joinUrl        String?       @map("join_url")
  idempotencyKey  String        @unique @map("idempotency_key")
  appointmentType String        @default("online") @map("appointment_type")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization  Organization   @relation(fields: [organizationId], references: [id])
  host          User           @relation("HostBookings", fields: [hostId], references: [id])
  meetingType   MeetingType    @relation(fields: [meetingTypeId], references: [id])
  answers       BookingAnswer[] // normalized from answers_json
  tokens        BookingToken[]
  reminderJobs  ReminderJob[]
  outbox        Outbox[]
  notifications NotificationAudit[]

  @@index([organizationId, hostId, status])
  @@index([organizationId, startsAt])
  @@map("bookings")
}

// Normalized from bookings.answers_json — one row per question answered
model BookingAnswer {
  id         String @id @default(uuid()) @db.Uuid
  bookingId  String @map("booking_id") @db.Uuid
  questionId String @map("question_id") @db.Uuid
  answer     String // text; for multiselect, comma-separated option ids

  booking  Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  question MeetingTypeQuestion @relation(fields: [questionId], references: [id])

  @@unique([bookingId, questionId])
  @@map("booking_answers")
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  RESCHEDULED
  PENDING

  @@map("booking_status")
}

// Single-use signed guest self-service tokens (§7 rule 9)
model BookingToken {
  id        String      @id @default(uuid()) @db.Uuid
  bookingId String      @map("booking_id") @db.Uuid
  action    TokenAction
  tokenHash String      @unique @map("token_hash") // SHA-256; raw token never stored
  expiresAt DateTime    @map("expires_at")
  usedAt    DateTime?   @map("used_at")
  createdAt DateTime    @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("booking_tokens")
}

enum TokenAction {
  RESCHEDULE
  CANCEL

  @@map("token_action")
}

// ─── OAuth Integrations ───────────────────────────────────────────────────────

model OAuthIntegration {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  ownerUserId    String   @map("owner_user_id") @db.Uuid
  provider       String   // google | microsoft | zoom | teams | webex
  accessToken    String   @map("access_token")  // encrypted at rest (KMS)
  refreshToken   String?  @map("refresh_token") // encrypted at rest
  tokenExpiresAt DateTime @map("token_expires_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization          @relation(fields: [organizationId], references: [id])
  owner        User                  @relation(fields: [ownerUserId], references: [id])
  scopes       OAuthIntegrationScope[] // normalized from scopes TEXT[]

  @@unique([organizationId, ownerUserId, provider])
  @@index([organizationId])
  @@map("oauth_integrations")
}

// Normalized from oauth_integrations.scopes TEXT[]
model OAuthIntegrationScope {
  integrationId String @map("integration_id") @db.Uuid
  scope         String

  integration OAuthIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@id([integrationId, scope])
  @@map("oauth_integration_scopes")
}

// ─── Developer API ────────────────────────────────────────────────────────────

model ApiKey {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  clientId       String    @unique @map("client_id")
  keyHash        String    @map("key_hash") // SHA-256 of raw key; never stored plain
  prefix         String    // slotq_live_… or slotq_test_…
  lastUsedAt     DateTime? @map("last_used_at")
  revokedAt      DateTime? @map("revoked_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization     Organization      @relation(fields: [organizationId], references: [id])
  webhookEndpoints WebhookEndpoint[]

  @@index([organizationId])
  @@map("api_keys")
}

model WebhookEndpoint {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  apiKeyId       String?  @map("api_key_id") @db.Uuid
  url            String
  signingSecret  String   @map("signing_secret") // encrypted; used for HMAC-SHA256
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization  Organization              @relation(fields: [organizationId], references: [id])
  apiKey        ApiKey?                   @relation(fields: [apiKeyId], references: [id])
  subscriptions WebhookEventSubscription[] // normalized from event_types TEXT[]
  deliveries    WebhookDelivery[]

  @@index([organizationId])
  @@map("webhook_endpoints")
}

// Normalized from webhook_endpoints.event_types TEXT[]
model WebhookEventSubscription {
  endpointId String @map("endpoint_id") @db.Uuid
  eventType  String @map("event_type")

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@id([endpointId, eventType])
  @@map("webhook_event_subscriptions")
}

model WebhookDelivery {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  endpointId     String               @map("endpoint_id") @db.Uuid
  eventType      String               @map("event_type")
  payloadJson    Json                 @map("payload_json") // event payload varies per type
  status         WebhookDeliveryStatus @default(PENDING)
  attempts       Int                  @default(0)
  lastAttemptAt  DateTime?            @map("last_attempt_at")
  responseStatus Int?                 @map("response_status")
  createdAt      DateTime             @default(now()) @map("created_at")

  organization Organization    @relation(fields: [organizationId], references: [id])
  endpoint     WebhookEndpoint @relation(fields: [endpointId], references: [id])

  @@index([organizationId, status])
  @@map("webhook_deliveries")
}

enum WebhookDeliveryStatus {
  PENDING
  DONE
  FAILED
  DEAD

  @@map("webhook_delivery_status")
}

// ─── Notifications & Audit ────────────────────────────────────────────────────

model NotificationAudit {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  bookingId      String?       @map("booking_id") @db.Uuid
  recipientRole  RecipientRole @map("recipient_role")
  recipientEmail String        @map("recipient_email")
  templateName   String        @map("template_name")
  result         NotifyResult
  providerMsgId  String?       @map("provider_msg_id")
  createdAt      DateTime      @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  booking      Booking?     @relation(fields: [bookingId], references: [id])

  @@index([organizationId, bookingId])
  @@map("notification_audit")
}

enum RecipientRole {
  host
  guest
}

enum NotifyResult {
  sent
  bounced
  failed
}

model ReminderJob {
  id          String         @id @default(uuid()) @db.Uuid
  bookingId   String         @map("booking_id") @db.Uuid
  fireAt      DateTime       @map("fire_at")
  status      ReminderStatus @default(PENDING)
  bullmqJobId String?        @map("bullmq_job_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([status, fireAt])
  @@map("reminder_jobs")
}

enum ReminderStatus {
  PENDING
  FIRED
  CANCELLED

  @@map("reminder_status")
}

// ─── Transactional Outbox (§9.1) ──────────────────────────────────────────────

model Outbox {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  aggregateType  String       @map("aggregate_type")
  aggregateId    String       @map("aggregate_id") @db.Uuid
  eventType      String       @map("event_type")
  payloadJson    Json         @map("payload_json") // event payload, varies per event type
  status         OutboxStatus @default(PENDING)
  attempts       Int          @default(0)
  nextAttemptAt  DateTime?    @map("next_attempt_at")
  idempotencyKey String       @unique @map("idempotency_key")
  processedAt    DateTime?    @map("processed_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  booking      Booking?     @relation(fields: [aggregateId], references: [id], map: "outbox_booking_fk")

  @@index([status, nextAttemptAt]) // drain worker query
  @@map("outbox")
}

enum OutboxStatus {
  PENDING
  DONE
  FAILED
  DEAD

  @@map("outbox_status")
}

// ─── AI Embeddings (pgvector) ─────────────────────────────────────────────────

model AiEmbedding {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  ownerUserId    String   @map("owner_user_id") @db.Uuid
  sourceType     String   @map("source_type") // booking | meeting_type
  sourceId       String   @map("source_id") @db.Uuid
  content        String
  metadata       Json     @default("{}") // legitimately flexible per source type
  // embedding column added via raw migration (vector(1536)); Prisma doesn't support vector natively
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  owner        User         @relation(fields: [ownerUserId], references: [id])

  @@index([organizationId, ownerUserId])
  @@map("ai_embeddings")
}

// ─── Admin Audit ──────────────────────────────────────────────────────────────

model AdminAudit {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  actorUserId    String   @map("actor_user_id") @db.Uuid
  action         String
  target         String
  metadata       Json     @default("{}") // varies per action type; legitimate JSONB use
  timestamp      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, actorUserId])
  @@map("admin_audit")
}

// ─── Feature Flags ────────────────────────────────────────────────────────────

model FeatureFlag {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  key            String
  enabled        Boolean  @default(false)
  payload        Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("feature_flags")
}
