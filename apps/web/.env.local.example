# apps/web/.env.local — copy this to apps/web/.env.local and fill in values
# Run scripts/register-authplex-client.sh first to register the OIDC client.

# AuthPlex OIDC — used by the browser to build the /authorize redirect URL only.
# Token exchange happens server-side in the Core API, not in the browser.
VITE_OIDC_ISSUER=http://localhost:8080
VITE_OIDC_CLIENT_ID=slotq-web
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback

# Core API base URL — all API calls (including auth) go here, not to AuthPlex
VITE_API_BASE_URL=http://localhost:3000
